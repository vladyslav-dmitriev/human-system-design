{
  "name": "my-turborepo",
  "packageManager": "npm@10.8.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "i18n:upload": "pnpm exec crowdin upload sources",
    "i18n:download": "pnpm exec crowdin download",
    "i18n:sync": "pnpm exec crowdin upload sources && crowdin download",
    "test:e2e": "pnpm --filter web build && pnpm --filter e2e exec playwright test",
    "test:e2e:ui": "pnpm --filter web build && pnpm --filter e2e exec playwright test --ui"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.14.2",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sentry/nextjs": "^10"
  }
}
