datasource db {
    provider = "postgresql" // или "sqlite", "mysql"
}

generator client {
    provider = "prisma-client-js"
    output   = "./generated/client"
}

model User {
    id        String   @id @default(cuid())
    name      String?
    email     String   @unique
    password  String // Хранит хэшированный пароль
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
